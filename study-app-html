function addCred() {
  const tag  = document.getElementById('cred-tag')?.value.trim();
  const url  = document.getElementById('cred-url')?.value.trim();
  const user = document.getElementById('cred-user')?.value.trim();
  const pass = document.getElementById('cred-pass')?.value.trim();
  if(!tag || !user) {
