// ── FI Portal Context Builder ──────────────────────────────────────────────
function buildPortalContext() {
  const links = (savedLinks || []).map((l,i) => `  [${i}] id:${l.id} | "${l.label}" | ${l.url} | tag:${l.tag}`).join('\n') || '  (none)';
  const creds = (savedCreds || []).map((c,i) => `  [${i}] "${c.tag}" | url:${c.url||'none'} | user:${c.user}`).join('\n') || '  (none)';
  const resources = (savedResources || []).map((r,i) => `  [${i}] "${r.title||r.url}" | ${r.url}`).join('\n') || '  (none)';
  const notes = (() => { try { return localStorage.getItem('workNotes') || '(empty)'; } catch(e) { return '(empty)'; } })();
  const campaign = (() => { try { return localStorage.getItem('campaign') || currentCampaign || 'Not set'; } catch(e) { return 'Not set'; } })();
  return `Campaign: ${campaign}
Quick Links:
${links}
Saved Logins (usernames only, no passwords shown):
${creds}
COI Resources:
${resources}
Work Notes (first 200 chars): ${notes.slice(0,200)}`;
}

// ── FI Action Executor ─────────────────────────────────────────────────────
function executeFIAction(actionStr) {
  // Parse [ACTION:type|{json}]
  const match = actionStr.match(/\[ACTION:([a-zA-Z]+)\|(\{.*\})\]/);
  if (!match) return null;
  const type = match[1];
  let params;
  try { params = JSON.parse(match[2]); } catch(e) { return 'Could not parse action parameters.'; }

  try {
    switch(type) {
      case 'addLink': {
        let url = params.url || '';
        if(url && !url.startsWith('http') && !url.startsWith('tel:') && !url.startsWith('mailto:')) url = 'https://' + url;
        if(!params.label || !url) return 'Missing label or URL for addLink.';
        savedLinks.push({ id: 'ql' + Date.now(), label: params.label, url, tag: params.tag || 'General' });
        saveLinksToStorage();
        renderLinks();
        return 'Link added: ' + params.label;
      }
      case 'deleteLink': {
        const idx = savedLinks.findIndex(l => l.id === params.id);
        if(idx === -1) return 'Link not found with that ID.';
        const removed = savedLinks[idx].label;
        savedLinks.splice(idx, 1);
        saveLinksToStorage();
        renderLinks();
        return 'Deleted link: ' + removed;
      }
      case 'editLink': {
        const idx = savedLinks.findIndex(l => l.id === params.id);
        if(idx === -1) return 'Link not found with that ID.';
        if(params.label) savedLinks[idx].label = params.label;
        if(params.url) {
          let url = params.url;
          if(!url.startsWith('http') && !url.startsWith('tel:') && !url.startsWith('mailto:')) url = 'https://' + url;
          savedLinks[idx].url = url;
        }
        if(params.tag) savedLinks[idx].tag = params.tag;
        saveLinksToStorage();
        renderLinks();
        return 'Link updated: ' + savedLinks[idx].label;
      }
      case 'addResource': {
        if(!params.url) return 'Missing URL for addResource.';
        savedResources.push({ title: params.title || params.url, url: params.url, note: params.note || '' });
        try { localStorage.setItem('myResources', JSON.stringify(savedResources)); } catch(e) {}
        renderResources();
        return 'Resource added: ' + (params.title || params.url);
      }
      case 'deleteResource': {
        if(params.index === undefined || params.index < 0 || params.index >= savedResources.length) return 'Invalid resource index.';
        const removed = savedResources[params.index].title || savedResources[params.index].url;
        savedResources.splice(params.index, 1);
        try { localStorage.setItem('myResources', JSON.stringify(savedResources)); } catch(e) {}
        renderResources();
        return 'Deleted resource: ' + removed;
      }
      case 'addCred': {
        if(!params.tag || !params.user) return 'Missing tag or username for addCred.';
        savedCreds.push({ tag: params.tag, url: params.url || '', user: params.user, pass: params.pass || '' });
        try { localStorage.setItem('myCredentials', JSON.stringify(savedCreds)); } catch(e) {}
        renderCreds();
        return 'Login saved: ' + params.tag;
      }
      case 'deleteCred': {
        if(params.index === undefined || params.index < 0 || params.index >= savedCreds.length) return 'Invalid credential index.';
        const removed = savedCreds[params.index].tag;
        savedCreds.splice(params.index, 1);
        try { localStorage.setItem('myCredentials', JSON.stringify(savedCreds)); } catch(e) {}
        renderCreds();
        return 'Deleted login: ' + removed;
      }
      case 'setCampaign': {
        if(!params.name) return 'Missing campaign name.';
        currentCampaign = params.name;
        try { localStorage.setItem('campaign', currentCampaign); } catch(e) {}
        updateCampaignDisplay();
        return 'Campaign set to: ' + params.name;
      }
      case 'appendWorkNotes': {
        if(!params.text) return 'No text to append.';
        const el = document.getElementById('work-notes-area');
        const existing = el ? el.value : (localStorage.getItem('workNotes') || '');
        const newVal = existing ? existing + '\n' + params.text : params.text;
        if(el) el.value = newVal;
        try { localStorage.setItem('workNotes', newVal); } catch(e) {}
        return 'Work notes updated.';
      }
      case 'navigate': {
        if(!params.view) return 'Missing view name.';
        switchView(params.view);
        return 'Navigated to: ' + params.view;
      }
      case 'navigateCOI': {
        if(!params.tab) return 'Missing tab name.';
        switchView('instructor');
        setTimeout(() => {
          const tabEl = document.querySelector('.coi-tab[onclick*="' + params.tab + '"]');
          if(tabEl) switchCOITab(params.tab, tabEl);
        }, 200);
        return 'Opened COI tab: ' + params.tab;
      }
      default:
        return 'Unknown action: ' + type;
    }
  } catch(err) {
    return 'Action error: ' + err.message;
  }
}

// ── FI Response Renderer (shared by both chat surfaces) ────────────────────
function renderFIResponse(rawReply, typingBubble) {
  // Strip action tags from display text
  const displayText = rawReply.replace(/\[ACTION:[^\]]+\]/g, '').trim();
  if(typingBubble) {
    typingBubble.innerHTML = displayText
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/\n/g, '<br>');
    typingBubble.style.opacity = '1';
  }
  // Execute any action found
  const actionMatch = rawReply.match(/\[ACTION:[a-zA-Z]+\|\{[^}]*\}(?:[^}]*\})*\]/);
  if(actionMatch) {
    const result = executeFIAction(actionMatch[0]);
    if(result && typingBubble) {
      const actionEl = document.createElement('div');
      actionEl.style.cssText = 'margin-top:8px;padding:6px 10px;background:rgba(76,175,130,0.12);border:1px solid rgba(76,175,130,0.3);border-radius:8px;font-size:0.75rem;color:#4caf82;font-weight:700;';
      actionEl.textContent = '✓ ' + result;
      typingBubble.appendChild(actionEl);
    }
  }
}

async function sendTutorMessage() {
  const input = document.getElementById('tutor-input');
  const question = input?.value.trim();
  const hasImage = !!tutorPendingImage;
  if(!question && !hasImage) return;

  const sugg = document.getElementById('tutor-suggestions');
  if(sugg) sugg.style.display = 'none';

  const displayText = question || '📷 What does this slide say?';
  input.value = '';
  input.style.height = 'auto';

  // Show user bubble (with image thumbnail if present)
  const chat = document.getElementById('tutor-chat');
  if(chat) {
    const wrap = document.createElement('div');
    wrap.className = 'tutor-bubble-wrap user';
    const avatar = document.createElement('div');
    avatar.className = 'tutor-avatar';
    avatar.style.cssText = 'background:rgba(232,146,58,0.15);color:var(--amber);font-size:0.7rem';
    avatar.textContent = 'YOU';
    const bubble = document.createElement('div');
    bubble.className = 'tutor-bubble user';
    bubble.innerHTML = (hasImage ? `<img src="data:${tutorPendingImage.mediaType};base64,${tutorPendingImage.base64}" style="max-width:180px;max-height:120px;border-radius:8px;display:block;margin-bottom:${question?'6px':'0'}">` : '') +
      (question ? question.replace(/\n/g,'<br>') : '');
    wrap.appendChild(avatar); wrap.appendChild(bubble); chat.appendChild(wrap);
    chat.scrollTop = chat.scrollHeight;
  }

  // Build message content for API
  const userContent = [];
  if(hasImage) {
    userContent.push({ type:'image', source:{ type:'base64', media_type: tutorPendingImage.mediaType, data: tutorPendingImage.base64 }});
  }
  userContent.push({ type:'text', text: question || 'Please read this slide and explain the key insurance concepts shown. Keep it short and exam-ready.' });

  fiHistory.push({ role:'user', content: userContent });
  clearTutorImage();

  const typingBubble = renderTutorMessage('ai', '', true);
  const btn = document.getElementById('tutor-send-btn');
  if(btn) btn.style.opacity = '0.5';

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: TUTOR_SYSTEM.replace('{{PORTAL_CONTEXT}}', buildPortalContext()),
        messages: fiHistory
      })
    });
    const data = await res.json();
    const reply = data?.content?.[0]?.text || 'Sorry, could not get a response. Try again.';
    fiHistory.push({ role:'assistant', content: reply });
    renderFIResponse(reply, typingBubble);
  } catch(err) {
    if(typingBubble) typingBubble.innerHTML = '⚠️ Connection error. Check your internet and try again.';
  }

  if(btn) btn.style.opacity = '1';
  if(chat) chat.scrollTop = chat.scrollHeight;
}

