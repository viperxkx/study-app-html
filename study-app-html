// ── Bar chart animation (runs on both home examdash and examdash) ──
function animateBars() {
  document.querySelectorAll('.bc-fill').forEach(el => {
    const w = el.getAttribute('data-w');
    if(w) setTimeout(() => { el.style.width = w + '%'; }, 200);
  });
}
// Run once on load and again when switching to examdash
animateBars();

// ── Sidebar tooltip — body-level element, never trapped by stacking contexts ──
const _tip = document.getElementById('sb-tooltip-global');
document.querySelectorAll('.sb-btn').forEach(btn => {
  const label = btn.getAttribute('title') || '';
  btn.removeAttribute('title'); // prevent native browser tooltip
  btn.addEventListener('mouseenter', () => {
    if(!label) return;
    _tip.textContent = label;
    const r = btn.getBoundingClientRect();
    _tip.style.top = (r.top + r.height / 2 - 13) + 'px';
    _tip.classList.add('visible');
  });
  btn.addEventListener('mouseleave', () => _tip.classList.remove('visible'));
  btn.addEventListener('click', () => _tip.classList.remove('visible'));
});


// ── Resources / Videos ──
const savedResources = JSON.parse(localStorage.getItem('myResources') || '[]');

function renderResources() {
  const list = document.getElementById('resource-list');
  if(!list) return;
  if(!savedResources.length) {
    list.innerHTML = `<div style="padding:18px;text-align:center;border:1.5px dashed var(--border2);border-radius:var(--r);color:var(--text3);font-size:0.82rem">No saved resources yet. Add a YouTube video or link above.</div>`;
    return;
  }
  list.innerHTML = savedResources.map((r,i) => {
    const isYT = r.url && (r.url.includes('youtube.com') || r.url.includes('youtu.be'));
    let ytId = '';
    if(isYT) {
      const m = r.url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
      if(m) ytId = m[1];
    }
    return `<div style="background:rgba(255,255,255,0.4);border:1px solid var(--border);border-radius:var(--r2);padding:13px 14px;margin-bottom:10px">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:8px">
        <div>
          <div style="font-size:0.83rem;font-weight:800;color:var(--text)">${r.title||'Untitled'}</div>
          ${r.note ? `<div style="font-size:0.76rem;color:var(--text3);margin-top:2px">${r.note}</div>` : ''}
        </div>
        <div style="display:flex;gap:7px;flex-shrink:0">
          <a href="${r.url}" target="_blank" style="padding:5px 10px;background:var(--amber-g);color:white;border-radius:99px;font-size:0.72rem;font-weight:700;text-decoration:none">Open</a>
          <button onclick="deleteResource(${i})" style="background:rgba(224,90,90,0.1);border:1px solid rgba(224,90,90,0.2);border-radius:99px;padding:5px 9px;cursor:pointer;font-size:0.72rem;color:var(--red);font-weight:700">Remove</button>
        </div>
      </div>
      ${ytId ? `<div style="position:relative;padding-top:52%;border-radius:var(--r2);overflow:hidden"><iframe style="position:absolute;top:0;left:0;width:100%;height:100%;border:0" src="https://www.youtube.com/embed/${ytId}" allowfullscreen loading="lazy"></iframe></div>` : ''}
    </div>`;
  }).join('');
}

function addResource() {
  const title = document.getElementById('res-title').value.trim();
  const url = document.getElementById('res-url').value.trim();
  const note = document.getElementById('res-note').value.trim();
  if(!url) return alert('Add a URL first');
  savedResources.push({title: title||url, url, note});
  try { localStorage.setItem('myResources', JSON.stringify(savedResources)); } catch(e){}
  ['res-title','res-url','res-note'].forEach(id => { const el = document.getElementById(id); if(el) el.value = ''; });
  renderResources();
}

function deleteResource(i) {
  savedResources.splice(i, 1);
  try { localStorage.setItem('myResources', JSON.stringify(savedResources)); } catch(e){}
  renderResources();
}

renderResources();

// Wire up float chat button AFTER all functions are defined
document.addEventListener('DOMContentLoaded', function() {
