  if(fcb) fcb.addEventListener('click', toggleFloatChat);
});
// Also wire immediately in case DOM already loaded
(function() {
  const fcb = document.getElementById('float-chat-btn');
  if(fcb) fcb.addEventListener('click', toggleFloatChat);
})();

</script>
