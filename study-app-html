<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FL Insurance — Study Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #f2ebe0;
  --bg2:       #ede4d6;
  --panel:     rgba(255,255,255,0.55);
  --panel2:    rgba(255,255,255,0.38);
  --panel3:    rgba(255,255,255,0.72);
  --border:    rgba(255,255,255,0.82);
  --border2:   rgba(210,190,165,0.35);
  --shadow:    0 8px 40px rgba(160,120,70,0.11);
  --shadow2:   0 2px 12px rgba(160,120,70,0.07);

  /* accent palette — warm amber/orange like the reference */
  --amber:     #e8923a;
  --amber2:    #f0a84e;
  --amber-g:   linear-gradient(135deg,#e8923a,#f0c060);
  --peach:     #e87a52;
  --cream:     #f5ede0;
  --gold:      #c97b2e;

  /* status colours */
  --green:     #4caf82;
  --green-s:   rgba(76,175,130,0.15);
  --red:       #e05a5a;
  --red-s:     rgba(224,90,90,0.13);
  --blue:      #6b9fd4;
  --blue-s:    rgba(107,159,212,0.15);
  --purple:    #9b7fc7;

  /* text */
  --text:      #2d2416;
  --text2:     #6b5940;
  --text3:     #a08c72;

  --r:  16px;
  --r2: 12px;
  --r3: 24px;
}

*, *::before, *::after { box-sizing: border-box; margin:0; padding:0; }

body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* warm texture orbs */
body::before {
  content:'';
  position:fixed; top:-180px; left:-120px;
  width:700px; height:700px;
  background: radial-gradient(circle, rgba(232,180,100,0.22) 0%, transparent 65%);
  pointer-events:none; z-index:0;
}
body::after {
  content:'';
  position:fixed; bottom:-150px; right:-100px;
  width:600px; height:600px;
  background: radial-gradient(circle, rgba(230,155,90,0.16) 0%, transparent 65%);
  pointer-events:none; z-index:0;
}
.orb3 {
  position:fixed; top:50%; left:60%;
  width:400px; height:400px;
  transform:translate(-50%,-50%);
  background: radial-gradient(circle, rgba(255,220,160,0.13) 0%, transparent 65%);
  pointer-events:none; z-index:0;
}

/* ============================================================
   APP SHELL
   ============================================================ */
.app {
  display:flex;
  min-height:100vh;
  position:relative; z-index:1;
}

/* ============================================================
   SIDEBAR  — thin icon rail like reference
   ============================================================ */
.sidebar {
  width: 64px;
  flex-shrink:0;
  background: rgba(255,255,255,0.42);
  backdrop-filter: blur(28px) saturate(1.5);
  -webkit-backdrop-filter: blur(28px) saturate(1.5);
  border-right: 1px solid rgba(255,255,255,0.75);
  box-shadow: 2px 0 24px rgba(160,120,70,0.07);
  display:flex;
  flex-direction:column;
  align-items:center;
  padding:20px 0 20px;
  position:sticky; top:0; height:100vh;
  gap:4px;
}
.sb-logo {
  width:36px; height:36px;
  background: var(--amber-g);
  border-radius:10px;
  display:flex; align-items:center; justify-content:center;
  font-size:1rem; font-weight:900; color:white;
  margin-bottom:20px;
  box-shadow: 0 4px 12px rgba(232,146,58,0.4);
  flex-shrink:0;
  letter-spacing:-1px;
}
.sb-nav {
  display:flex; flex-direction:column; align-items:center;
  gap:4px; flex:1;
}
.sb-btn {
  width:44px; height:44px;
  border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.15rem;
  cursor:pointer;
  background:none; border:none;
  color:var(--text3);
  position:relative;
  /* NO transition:all — that creates a stacking context trapping fixed children */
  transition:background 0.2s, color 0.2s;
}
.sb-btn:hover { background:rgba(255,255,255,0.5); color:var(--amber); }
.sb-btn.active {
  background: var(--amber-g);
  color:white;
  box-shadow:0 4px 14px rgba(232,146,58,0.35);
}
/* Single shared tooltip rendered at body level — never inside a button */
#sb-tooltip-global {
  position:fixed;
  left:74px;
  background:rgba(30,22,12,0.95);
  color:white;
  font-size:0.72rem; font-weight:700;
  padding:5px 12px;
  border-radius:7px;
  white-space:nowrap;
  pointer-events:none;
  opacity:0;
  transition:opacity 0.12s;
  z-index:2147483647;
  box-shadow:0 4px 16px rgba(0,0,0,0.3);
}
#sb-tooltip-global.visible { opacity:1; }
/* hide the old inline tooltips in case any remain */
.sb-tooltip { display:none !important; }
.sb-divider {
  width:28px; height:1px;
  background:var(--border2);
  margin:6px 0;
}

/* ============================================================
   MAIN CONTENT AREA
   ============================================================ */
.main {
  flex:1; min-width:0;
  padding:24px 24px 32px;
  overflow-y:auto;
}

/* ============================================================
   TOP BAR
   ============================================================ */
.topbar {
  display:flex;
  align-items:center;
  gap:14px;
  margin-bottom:22px;
}
.page-title {
  font-size:1.4rem;
  font-weight:800;
  color:var(--text);
  letter-spacing:-0.5px;
  flex:1;
}
.search-wrap { position:relative; }
.search-input {
  background: rgba(255,255,255,0.55);
  backdrop-filter:blur(10px);
  border:1px solid var(--border);
  border-radius:99px;
  padding:9px 16px 9px 36px;
  font-family:'Plus Jakarta Sans',sans-serif;
  font-size:0.82rem;
  color:var(--text);
  width:200px;
  outline:none;
  transition:all 0.2s;
  box-shadow:var(--shadow2);
}
.search-input::placeholder { color:var(--text3); }
.search-input:focus {
  border-color:var(--amber);
  width:260px;
  background:rgba(255,255,255,0.75);
}
.search-icon {
  position:absolute; left:12px; top:50%;
  transform:translateY(-50%);
  font-size:0.85rem; color:var(--text3);
  pointer-events:none;
}
.search-results {
  display:none;
  position:absolute; top:calc(100% + 8px); right:0;
  width:340px;
  background:rgba(250,244,236,0.97);
  backdrop-filter:blur(20px);
  border:1px solid var(--border);
  border-radius:var(--r);
  z-index:999;
  max-height:340px; overflow-y:auto;
  box-shadow:0 16px 48px rgba(140,100,50,0.18);
}
.search-results.show { display:block; }
.sr-item { padding:11px 16px; border-bottom:1px solid rgba(200,180,155,0.2); cursor:pointer; transition:background 0.15s; }
.sr-item:hover { background:rgba(232,146,58,0.08); }
.sr-item:last-child { border-bottom:none; }
.sr-term { font-size:0.83rem; font-weight:700; color:var(--amber); }
.sr-def { font-size:0.76rem; color:var(--text2); margin-top:2px; line-height:1.4; }
.sr-empty { padding:18px; text-align:center; color:var(--text3); font-size:0.85rem; }

/* ============================================================
   VIEWS
   ============================================================ */
.view { display:none; }
.view.active { display:block; }

/* ============================================================
   GLASS CARD — the base panel unit
   ============================================================ */
.gc {
  background: var(--panel);
  backdrop-filter: blur(20px) saturate(1.3);
  -webkit-backdrop-filter: blur(20px) saturate(1.3);
  border: 1px solid var(--border);
  border-radius: var(--r3);
  box-shadow: var(--shadow);
  padding:20px;
}
.gc-title {
  font-size:0.7rem; font-weight:700;
  text-transform:uppercase; letter-spacing:1px;
  color:var(--text3);
  margin-bottom:14px;
}

/* ============================================================
   HOME — DASHBOARD
   ============================================================ */
.dash-top {
  display:grid;
  grid-template-columns:1fr 260px;
  gap:16px;
  margin-bottom:16px;
}
.dash-left { display:flex; flex-direction:column; gap:16px; }

/* stat ribbon */
.stat-ribbon {
  background: var(--panel);
  backdrop-filter:blur(20px) saturate(1.3);
  border:1px solid var(--border);
  border-radius:var(--r3);
  box-shadow:var(--shadow);
  padding:18px 22px;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0;
}
.stat-ribbon-item {
  display:flex; align-items:center; gap:12px;
  padding:0 18px 0 0;
}
.stat-ribbon-item + .stat-ribbon-item {
  border-left:1px solid var(--border2);
  padding-left:18px;
}
.srb-icon {
  width:38px; height:38px; border-radius:10px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.1rem; flex-shrink:0;
}
.srb-val { font-size:1.25rem; font-weight:800; letter-spacing:-0.5px; }
.srb-lbl { font-size:0.68rem; color:var(--text3); margin-top:1px; font-weight:600; }
.srb-sub { font-size:0.7rem; color:var(--text3); margin-top:3px; }

/* chart area */
.chart-panel {
  background:var(--panel);
  backdrop-filter:blur(20px) saturate(1.3);
  border:1px solid var(--border);
  border-radius:var(--r3);
  box-shadow:var(--shadow);
  padding:20px 22px;
}
.chart-header {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:16px;
}
.chart-header-title { font-size:0.95rem; font-weight:700; color:var(--text); }
.chart-legend {
  display:flex; gap:12px; align-items:center;
  font-size:0.7rem; color:var(--text3);
}
.leg-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

/* SVG chart */
.chart-svg-wrap { width:100%; height:130px; position:relative; }
svg.linechart { width:100%; height:100%; overflow:visible; }

/* bar chart (exam weight) */
.bar-chart { display:flex; flex-direction:column; gap:10px; }
.bc-row { display:flex; align-items:center; gap:10px; }
.bc-lbl { font-size:0.71rem; color:var(--text2); width:115px; flex-shrink:0; line-height:1.3; }
.bc-track { flex:1; height:7px; background:rgba(160,140,114,0.15); border-radius:99px; overflow:hidden; }
.bc-fill { height:100%; border-radius:99px; transition:width 1.1s cubic-bezier(0.4,0,0.2,1); }
.bc-pct { font-size:0.71rem; font-weight:700; width:28px; text-align:right; }

/* right panel — exam info card */
.dash-right { display:flex; flex-direction:column; gap:16px; }

.exam-card {
  background: linear-gradient(145deg, rgba(232,146,58,0.85), rgba(240,168,78,0.75));
  backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,0.5);
  border-radius:var(--r3);
  box-shadow:0 8px 32px rgba(200,120,40,0.25);
  padding:20px;
  color:white;
  position:relative;
  overflow:hidden;
}
.exam-card::before {
  content:'';
  position:absolute; top:-40px; right:-40px;
  width:140px; height:140px;
  background:rgba(255,255,255,0.12);
  border-radius:50%;
}
.exam-card::after {
  content:'';
  position:absolute; bottom:-30px; left:-20px;
  width:100px; height:100px;
  background:rgba(255,255,255,0.08);
  border-radius:50%;
}
.ec-label { font-size:0.68rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; opacity:0.85; margin-bottom:4px; }
.ec-name { font-size:1rem; font-weight:800; margin-bottom:16px; line-height:1.2; }
.ec-row { display:flex; gap:12px; justify-content:space-between; position:relative; z-index:1; }
.ec-stat { text-align:center; }
.ec-stat-val { font-size:1.3rem; font-weight:800; letter-spacing:-0.5px; }
.ec-stat-lbl { font-size:0.65rem; opacity:0.82; margin-top:1px; font-weight:600; }

/* month transactions style — chapter list */
.ch-list { display:flex; flex-direction:column; gap:8px; }
.ch-item {
  display:flex; align-items:center; gap:12px;
  padding:10px 14px;
  background:rgba(255,255,255,0.35);
  border-radius:var(--r2);
  border:1px solid var(--border);
  cursor:pointer;
  transition:all 0.18s;
}
.ch-item:hover { background:rgba(255,255,255,0.55); transform:translateX(2px); }
.ch-icon {
  width:34px; height:34px; border-radius:9px;
  display:flex; align-items:center; justify-content:center;
  font-size:0.95rem; flex-shrink:0;
}
.ch-info { flex:1; }
.ch-name2 { font-size:0.82rem; font-weight:700; color:var(--text); }
.ch-meta { font-size:0.7rem; color:var(--text3); margin-top:2px; }
.ch-pct2 {
  font-size:0.8rem; font-weight:800;
  padding:3px 10px;
  border-radius:99px;
  background:rgba(232,146,58,0.12);
  color:var(--amber);
}

/* bottom row */
.dash-bottom {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px;
}

/* roadmap steps */
.road-list { display:flex; flex-direction:column; gap:8px; }
.road-item {
  display:flex; align-items:center; gap:10px;
  padding:9px 12px;
  background:rgba(255,255,255,0.30);
  border-radius:var(--r2);
  border:1px solid var(--border);
}
.rnum {
  width:24px; height:24px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:0.68rem; font-weight:800; flex-shrink:0;
}
.rtext { font-size:0.78rem; color:var(--text2); line-height:1.35; }
.rtext strong { color:var(--text); display:block; font-size:0.8rem; }

/* ============================================================
   NOTES
   ============================================================ */
.chapter-tabs {
  display:flex; gap:6px; flex-wrap:wrap; margin-bottom:18px;
}
.ch-tab {
  background:rgba(255,255,255,0.40);
  border:1px solid var(--border);
  border-radius:99px;
  padding:6px 16px;
  font-size:0.78rem; font-weight:600;
  color:var(--text2);
  cursor:pointer;
  transition:all 0.18s;
  font-family:'Plus Jakarta Sans',sans-serif;
  box-shadow:var(--shadow2);
}
.ch-tab:hover { background:rgba(255,255,255,0.65); }
.ch-tab.active {
  background: var(--amber-g);
  border-color:transparent;
  color:white;
  box-shadow:0 4px 14px rgba(232,146,58,0.3);
}

/* COI top-level tabs */
.coi-tab {
  display:flex;align-items:center;gap:5px;
  background:transparent;
  border:none;
  border-radius:8px;
  padding:7px 12px;
  font-size:0.78rem; font-weight:600;
  color:var(--text3);
  cursor:pointer;
  transition:all 0.15s;
  font-family:'Plus Jakarta Sans',sans-serif;
  white-space:nowrap;
}
.coi-tab:hover { background:rgba(255,255,255,0.65); color:var(--text); }
.coi-tab.active {
  background:white;
  color:var(--text);
  box-shadow:0 2px 8px rgba(0,0,0,0.08);
  font-weight:800;
}
.coi-tab.active svg { stroke:var(--amber); }
.coi-panel { display:none; }
.coi-panel.active { display:block; }

.concept {
  background:var(--panel);
  backdrop-filter:blur(16px);
  border:1px solid var(--border);
  border-radius:var(--r);
  margin-bottom:10px;
  overflow:hidden;
  box-shadow:var(--shadow2);
}
.concept-hdr {
  padding:13px 18px;
  cursor:pointer;
  display:flex; align-items:center; justify-content:space-between; gap:12px;
  transition:background 0.15s;
  user-select:none;
}
.concept-hdr:hover { background:rgba(255,255,255,0.3); }
.concept-hdr-l { display:flex; align-items:center; gap:10px; }
.c-emoji { font-size:1rem; }
.c-title { font-size:0.88rem; font-weight:700; color:var(--text); }
.c-arrow { font-size:0.7rem; color:var(--text3); transition:transform 0.2s; }
.concept.open .c-arrow { transform:rotate(180deg); }
.concept-body {
  display:none;
  padding:0 18px 16px;
  border-top:1px solid rgba(200,180,155,0.2);
}
.concept.open .concept-body { display:block; padding-top:14px; }
.concept p,.concept li { font-size:0.85rem; line-height:1.7; color:var(--text2); }
.concept ul,.concept ol { padding-left:18px; margin-top:7px; }
.concept li { margin-bottom:3px; }
.highlight {
  background:rgba(232,146,58,0.10);
  border-left:3px solid var(--amber);
  border-radius:0 8px 8px 0;
  padding:9px 13px;
  margin-top:11px;
  font-size:0.8rem;
  color:var(--gold);
  font-weight:600;
}
.formula {
  background:rgba(76,175,130,0.10);
  border:1px solid rgba(76,175,130,0.3);
  border-radius:10px;
  padding:11px 16px;
  margin-top:11px;
  font-size:0.88rem;
  color:#2e7a56;
  font-weight:700;
  text-align:center;
}
.mini-t { width:100%; border-collapse:collapse; margin-top:11px; font-size:0.8rem; }
.mini-t th {
  background:rgba(200,175,140,0.15);
  padding:7px 12px; text-align:left;
  font-weight:700; color:var(--text3);
  border-bottom:1px solid rgba(200,175,140,0.2);
  font-size:0.72rem; text-transform:uppercase; letter-spacing:0.4px;
}
.mini-t td { padding:7px 12px; border-bottom:1px solid rgba(200,175,140,0.12); color:var(--text2); }
.mini-t tr:last-child td { border-bottom:none; }

/* ============================================================
   FLASHCARDS
   ============================================================ */
.fc-bar-row {
  display:flex; align-items:center; gap:12px; margin-bottom:18px;
}
.fc-bar-lbl { font-size:0.78rem; color:var(--text2); }
.fc-prog-track {
  flex:1; height:5px;
  background:rgba(160,140,114,0.2);
  border-radius:99px; overflow:hidden;
}
.fc-prog-fill {
  height:100%;
  background:var(--amber-g);
  border-radius:99px;
  transition:width 0.3s ease;
}
.fc-count-lbl { font-size:0.78rem; font-weight:700; color:var(--text2); }

.fc-scene {
  perspective:1200px; height:230px; cursor:pointer; margin-bottom:18px;
}
.fc-inner {
  width:100%; height:100%;
  position:relative; transform-style:preserve-3d;
  transition:transform 0.5s cubic-bezier(0.4,0,0.2,1);
}
.fc-inner.flipped { transform:rotateY(180deg); }
.fc-face {
  position:absolute; width:100%; height:100%;
  backface-visibility:hidden;
  border-radius:var(--r3);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  padding:32px; text-align:center;
}
.fc-front {
  background:var(--panel3);
  backdrop-filter:blur(20px);
  border:1px solid var(--border);
  box-shadow:var(--shadow);
}
.fc-back {
  background:linear-gradient(145deg, rgba(232,146,58,0.82), rgba(240,192,96,0.72));
  border:1px solid rgba(255,255,255,0.6);
  box-shadow:0 8px 32px rgba(200,120,40,0.22);
  transform:rotateY(180deg);
  color:white;
}
.fc-badge {
  font-size:0.62rem; font-weight:700; letter-spacing:2px; text-transform:uppercase;
  margin-bottom:12px;
  padding:3px 12px;
  border-radius:99px;
}
.fc-front .fc-badge { background:rgba(160,140,114,0.15); color:var(--text3); }
.fc-back .fc-badge { background:rgba(255,255,255,0.2); color:rgba(255,255,255,0.85); }
.fc-term { font-size:1.25rem; font-weight:800; color:var(--text); letter-spacing:-0.3px; line-height:1.3; }
.fc-back .fc-term { display:none; }
.fc-def { font-size:0.88rem; line-height:1.6; color:rgba(255,255,255,0.95); }
.fc-hint { position:absolute; bottom:14px; font-size:0.68rem; color:var(--text3); }
.fc-back .fc-hint { color:rgba(255,255,255,0.6); }

.fc-controls {
  display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:14px;
}
.fc-count { font-size:0.82rem; font-weight:700; color:var(--text2); min-width:65px; text-align:center; }
.fc-actions { display:flex; gap:10px; justify-content:center; }

/* ============================================================
   QUIZ
   ============================================================ */
.quiz-topbar {
  display:flex; align-items:center; gap:12px; margin-bottom:18px;
}
.quiz-prog-track { flex:1; height:6px; background:rgba(160,140,114,0.2); border-radius:99px; overflow:hidden; }
.quiz-prog-fill { height:100%; background:var(--amber-g); border-radius:99px; transition:width 0.4s ease; }
.quiz-score-row { display:flex; gap:12px; align-items:center; font-size:0.78rem; color:var(--text3); }
.qdot { width:8px; height:8px; border-radius:50%; display:inline-block; }
.quiz-q { font-size:1rem; font-weight:700; line-height:1.5; margin-bottom:18px; color:var(--text); }
.quiz-opts { display:grid; gap:9px; margin-bottom:14px; }
.qopt {
  background:rgba(255,255,255,0.45);
  border:1px solid var(--border);
  border-radius:var(--r);
  padding:12px 16px;
  text-align:left; cursor:pointer;
  font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem;
  color:var(--text2);
  display:flex; align-items:flex-start; gap:10px;
  transition:all 0.15s;
  box-shadow:var(--shadow2);
}
