let currentDay = 0;
const savedChecks = JSON.parse(localStorage.getItem('dailyChecks') || '{}');

function setDay(idx, el) {
  currentDay = idx;
  document.querySelectorAll('.day-pill').forEach(p => p.classList.remove('active'));
  if(el) el.classList.add('active');
  else document.querySelectorAll('.day-pill')[idx]?.classList.add('active');
  renderDailyContent();
}

function changeDay(dir) {
  const newDay = Math.max(0, Math.min(9, currentDay + dir));
  const pills = document.querySelectorAll('.day-pill');
  setDay(newDay, pills[newDay]);
}

function toggleTask(id) {
  savedChecks[id] = !savedChecks[id];
  try { localStorage.setItem('dailyChecks', JSON.stringify(savedChecks)); } catch(e){}
  renderDailyContent();
}

function renderDailyContent() {
  const d = dayData[currentDay];
  document.getElementById('daily-title').textContent = d.label;
  document.getElementById('daily-subtitle').textContent = d.chapter;
  document.getElementById('daily-counter').textContent = `Day ${d.day} of 10`;

  const completedTasks = d.tasks.filter(t => savedChecks[t.id]).length;
  const totalTasks = d.tasks.length;
  const pct = totalTasks ? Math.round((completedTasks / totalTasks) * 100) : 0;

  const adhdTips = [
    "Focus tip: Read in 25-minute blocks. Set a timer, then take a 5-minute break. Don't push through fatigue.",
    "Focus tip: Say answers out loud when doing flashcards. Hearing yourself helps retention.",
    "Focus tip: If you're stuck on a concept, skip it, keep moving, and come back. Don't get trapped.",
    "Focus tip: Use the accordion notes — don't open everything at once. One section at a time.",
    "Focus tip: Reward yourself after each completed task. A small break, a snack, something you enjoy.",
    "Focus tip: Do flashcards standing up or walking around. Movement helps with memory.",
    "Focus tip: Two chapters per day is a lot. It's okay to re-read a section twice if it doesn't click.",
    "Focus tip: After finishing both chapters, do a quick 10-min flashcard run before bed. Spaced repetition works.",
    "Focus tip: You're in the final stretch. Consistent short sessions beat marathon cramming every time.",
    "Focus tip: You've made it to Day 10. You know more than you think. Trust your preparation today.",
  ];

  let html = `
    <div class="gc" style="margin-bottom:14px;padding:16px 18px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
        <div style="display:flex;align-items:center;gap:10px">
          <div style="width:34px;height:34px;border-radius:10px;background:${d.color};opacity:0.15;flex-shrink:0"></div>
          <div>
            <div style="font-size:0.82rem;font-weight:800;color:${d.color}">${d.examWeight}</div>
            <div style="font-size:0.78rem;color:var(--text3);margin-top:1px">${completedTasks} of ${totalTasks} tasks done today</div>
          </div>
        </div>
        <div style="font-size:1.6rem;font-weight:800;color:${pct>=100?'var(--green)':d.color}">${pct}%</div>
      </div>
      <div style="height:8px;background:rgba(160,140,114,0.15);border-radius:99px;overflow:hidden">
        <div style="height:100%;width:${pct}%;background:${pct>=100?'var(--green)':'var(--amber-g)'};border-radius:99px;transition:width 0.4s ease"></div>
      </div>
      <div style="margin-top:10px;font-size:0.82rem;color:var(--text2);font-style:italic">${d.focus}</div>
    </div>
    <div class="gc" style="margin-bottom:14px">
      <div class="daily-section-hdr">Today's Tasks — tap to check off</div>`;

  d.tasks.forEach(t => {
    const done = !!savedChecks[t.id];
    html += `<div class="task-row ${done?'done-task':''}" onclick="toggleTask('${t.id}')">
      <div class="task-check">${done?'✓':''}</div>
      <div style="flex:1">
        <div class="task-label">${t.label}</div>
        <div class="task-sub">${t.sub}</div>
      </div>
      ${t.link?`<button class="btn-ghost sm" style="flex-shrink:0" onclick="event.stopPropagation();switchViewById('${t.link}')">Go →</button>`:''}
    </div>`;
  });
  html += `</div>`;

  if(d.keyTerms.length > 0) {
    html += `<div class="gc" style="margin-bottom:14px">
      <div class="daily-section-hdr">Key Terms to Know Today</div>
      <div style="display:flex;flex-wrap:wrap;gap:4px">`;
    d.keyTerms.forEach(t => { html += `<span class="focus-word">${t}</span>`; });
    html += `</div></div>`;
  }

  if(d.quickFacts.length > 0) {
    html += `<div class="gc" style="margin-bottom:14px">
      <div class="daily-section-hdr">Quick Facts — read these out loud</div>
      <div style="display:flex;flex-direction:column;gap:8px">`;
    d.quickFacts.forEach((f,i) => {
      html += `<div style="display:flex;gap:10px;align-items:flex-start;padding:9px 12px;background:rgba(255,255,255,0.35);border-radius:var(--r2);border:1px solid var(--border)">
