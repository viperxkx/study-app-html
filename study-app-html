// ── Quick Links ──
const defaultLinks = [
  {id:'ql1', label:'Adobe Room — Join Class', url:'https://sitelgroup.adobeconnect.com/destiny/', tag:'Training'},
  {id:'ql2', label:'HR Portal',               url:'https://hr.work.com',                         tag:'HR'},
  {id:'ql3', label:'Destiny — 786-375-9128',  url:'tel:786-375-9128',                            tag:'Contact'},
  {id:'ql4', label:'IT Support — 1-800-346-3588', url:'tel:1-800-346-3588',                      tag:'Support'},
  {id:'ql5', label:'ExamFX',                  url:'https://www.examfx.com',                      tag:'Exam Prep'},
];

let savedLinks = [];
try {
  const stored = localStorage.getItem('quickLinks');
  savedLinks = stored ? JSON.parse(stored) : [...defaultLinks];
} catch(e) { savedLinks = [...defaultLinks]; }

let activeLinkTag = 'All';
let linkFormOpen = false;

const tagColors = {
  'Training':   {bg:'rgba(232,146,58,0.1)',  border:'rgba(232,146,58,0.3)',  text:'var(--amber)'},
  'HR':         {bg:'rgba(76,175,130,0.1)',   border:'rgba(76,175,130,0.3)',  text:'var(--green)'},
  'Contact':    {bg:'rgba(107,159,212,0.1)',  border:'rgba(107,159,212,0.3)', text:'var(--blue)'},
  'Support':    {bg:'rgba(224,90,90,0.1)',    border:'rgba(224,90,90,0.3)',   text:'var(--red)'},
  'Exam Prep':  {bg:'rgba(155,127,199,0.1)',  border:'rgba(155,127,199,0.3)', text:'var(--purple)'},
};

function getTagStyle(tag) {
  const c = tagColors[tag];
  if(c) return `background:${c.bg};border:1px solid ${c.border};color:${c.text}`;
  return `background:rgba(160,140,114,0.1);border:1px solid rgba(160,140,114,0.25);color:var(--text3)`;
}

function saveLinksToStorage() {
  try { localStorage.setItem('quickLinks', JSON.stringify(savedLinks)); } catch(e){}
}

function renderLinks() {
  // tag filter pills
  const allTags = ['All', ...new Set(savedLinks.map(l => l.tag).filter(Boolean))];
  const filterEl = document.getElementById('link-tag-filters');
  if(!filterEl) return;

  filterEl.innerHTML = allTags.map(t => `
    <button onclick="setLinkTag('${t}')" style="padding:4px 11px;border-radius:99px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.7rem;font-weight:800;cursor:pointer;transition:all 0.15s;
      ${activeLinkTag===t
        ? 'background:var(--amber-g);color:white;border:none;box-shadow:0 2px 8px rgba(232,146,58,0.25)'
        : 'background:rgba(255,255,255,0.45);border:1px solid var(--border2);color:var(--text3)'}">
      ${t}
    </button>`).join('');

  // link items
  const list = document.getElementById('links-list');
  if(!list) return;
  const filtered = activeLinkTag === 'All' ? savedLinks : savedLinks.filter(l => l.tag === activeLinkTag);

  if(!filtered.length) {
    list.innerHTML = `<div style="padding:14px;text-align:center;border:1.5px dashed var(--border2);border-radius:var(--r2);color:var(--text3);font-size:0.8rem">No links yet. Hit + Add Link above.</div>`;
    return;
  }

  list.innerHTML = filtered.map(link => `
    <div style="display:flex;align-items:center;gap:9px;padding:9px 11px;background:rgba(255,255,255,0.42);border:1px solid var(--border);border-radius:var(--r2);transition:background 0.15s" onmouseenter="this.style.background='rgba(255,255,255,0.7)'" onmouseleave="this.style.background='rgba(255,255,255,0.42)'">
      <a href="${link.url}" target="${link.url.startsWith('tel:') ? '_self' : '_blank'}" style="flex:1;display:flex;align-items:center;gap:9px;text-decoration:none;overflow:hidden">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
          ${link.url.startsWith('tel:')
            ? '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 18z"/>'
            : '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>'}
        </svg>
        <span style="font-size:0.82rem;font-weight:600;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${link.label}</span>
      </a>
      <span style="font-size:0.68rem;font-weight:800;padding:3px 8px;border-radius:99px;flex-shrink:0;${getTagStyle(link.tag)}">${link.tag||'—'}</span>
      <button onclick="removeLink('${link.id}')" title="Remove" style="flex-shrink:0;background:none;border:none;cursor:pointer;padding:4px;border-radius:6px;color:var(--text3);line-height:0;transition:all 0.15s" onmouseenter="this.style.color='var(--red)';this.style.background='rgba(224,90,90,0.08)'" onmouseleave="this.style.color='var(--text3)';this.style.background='none'">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>`).join('');
}

function setLinkTag(tag) {
  activeLinkTag = tag;
  renderLinks();
}

function toggleLinkForm() {
  linkFormOpen = !linkFormOpen;
  const form = document.getElementById('link-form');
  if(form) form.style.display = linkFormOpen ? 'flex' : 'none';
  const btn = document.getElementById('link-add-btn');
  if(btn) btn.innerHTML = linkFormOpen
    ? `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.8" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Cancel`
    : `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.8" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Add Link`;
  if(linkFormOpen) setTimeout(() => document.getElementById('lf-label')?.focus(), 50);
}

function saveLink() {
  const label = document.getElementById('lf-label')?.value.trim();
  const tag   = document.getElementById('lf-tag')?.value.trim() || 'General';
  let   url   = document.getElementById('lf-url')?.value.trim();
  if(!label || !url) { alert('Label and URL are both required.'); return; }
  if(!url.startsWith('http') && !url.startsWith('tel:') && !url.startsWith('mailto:')) url = 'https://' + url;
  savedLinks.push({ id: 'ql' + Date.now(), label, url, tag });
  saveLinksToStorage();
  ['lf-label','lf-tag','lf-url'].forEach(id => { const el = document.getElementById(id); if(el) el.value = ''; });
  toggleLinkForm();
  activeLinkTag = 'All';
  renderLinks();
}

function removeLink(id) {
  savedLinks = savedLinks.filter(l => l.id !== id);
  saveLinksToStorage();
  renderLinks();
}

// allow Enter key in URL field
document.getElementById('lf-url')?.addEventListener('keydown', e => { if(e.key === 'Enter') saveLink(); });

renderLinks();

const defaultCampaign = 'USAA';
let currentCampaign = localStorage.getItem('campaign') || defaultCampaign;

function updateCampaignDisplay() {
  document.getElementById('campaign-name-display').textContent = currentCampaign;
  const todayEl = document.getElementById('today-campaign-display');
  if(todayEl) todayEl.textContent = currentCampaign;
}

function startEditCampaign() {
  document.getElementById('campaign-view-mode').style.display = 'none';
  document.getElementById('campaign-edit-mode').style.display = 'flex';
  const inp = document.getElementById('campaign-input');
  inp.value = currentCampaign;
  inp.focus();
  inp.select();
}

function saveCampaign() {
  const val = document.getElementById('campaign-input').value.trim();
  if(val) {
    currentCampaign = val;
    try { localStorage.setItem('campaign', currentCampaign); } catch(e){}
    updateCampaignDisplay();
  }
  document.getElementById('campaign-view-mode').style.display = 'flex';
  document.getElementById('campaign-edit-mode').style.display = 'none';
}

function cancelCampaign() {
  document.getElementById('campaign-view-mode').style.display = 'flex';
  document.getElementById('campaign-edit-mode').style.display = 'none';
}

document.getElementById('campaign-input')?.addEventListener('keydown', e => {
  if(e.key === 'Enter') saveCampaign();
  if(e.key === 'Escape') cancelCampaign();
});

updateCampaignDisplay();

// ── Work Notes ──
const workNotesArea = document.getElementById('work-notes-area');
if(workNotesArea) {
  workNotesArea.value = localStorage.getItem('workNotes') || '';
}

function saveWorkNotes() {
  try { localStorage.setItem('workNotes', document.getElementById('work-notes-area').value); } catch(e){}
  const msg = document.getElementById('notes-saved-msg');
  if(msg) { msg.style.display = 'block'; setTimeout(() => msg.style.display = 'none', 2000); }
}

// auto-save on input
workNotesArea?.addEventListener('input', () => {
  clearTimeout(workNotesArea._t);
