  savedCreds.push({tag, url, user, pass});
  try { localStorage.setItem('myCredentials', JSON.stringify(savedCreds)); } catch(e) {}
  ['cred-tag','cred-url','cred-user'].forEach(id => { const el=document.getElementById(id); if(el) el.value=''; });
  const pw = document.getElementById('cred-pass');
  if(pw) { pw.value=''; pw.type='password'; }
  renderCreds();
