   ============================================================ */
.btn {
  background:var(--amber-g);
  color:white;
  border:none; border-radius:99px;
  padding:10px 22px;
  font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; font-weight:700;
  cursor:pointer; transition:all 0.2s;
  box-shadow:0 4px 14px rgba(232,146,58,0.3);
  display:inline-flex; align-items:center; gap:6px;
}
.btn:hover { opacity:0.88; transform:translateY(-1px); }
.btn-sm { padding:7px 16px; font-size:0.76rem; }
.btn-ghost {
  background:rgba(255,255,255,0.45);
  border:1px solid var(--border);
  color:var(--text2);
  font-family:'Plus Jakarta Sans',sans-serif; font-size:0.83rem; font-weight:600;
