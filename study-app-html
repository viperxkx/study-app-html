async function sendFloatMessage() {
  const input = document.getElementById('float-input');
  const question = input?.value.trim();
  const hasImage = !!floatPendingImage;
  if(!question && !hasImage) return;

  input.value = '';
  input.style.height = 'auto';

  // Show user bubble with image if present
  const msgs = document.getElementById('float-chat-messages');
  if(msgs) {
    const s = document.getElementById('float-suggestions');
    if(s) s.style.display = 'none';
    const wrap = document.createElement('div');
    wrap.className = 'float-msg-user';
    const avatar = document.createElement('div');
    avatar.className = 'float-avatar';
    avatar.style.cssText = 'background:rgba(232,146,58,0.15);color:var(--amber);font-size:0.6rem';
    avatar.textContent = 'YOU';
    const bubble = document.createElement('div');
    bubble.className = 'float-bubble-user';
    bubble.innerHTML = (hasImage ? `<img src="data:${floatPendingImage.mediaType};base64,${floatPendingImage.base64}" style="max-width:140px;max-height:90px;border-radius:7px;display:block;margin-bottom:${question?'5px':'0'}">` : '') +
      (question ? question.replace(/\n/g,'<br>') : '');
    wrap.appendChild(avatar); wrap.appendChild(bubble); msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
  }

  const userContent = [];
  if(hasImage) userContent.push({ type:'image', source:{ type:'base64', media_type: floatPendingImage.mediaType, data: floatPendingImage.base64 }});
  userContent.push({ type:'text', text: question || 'Read this slide and explain the key insurance concepts. Keep it short and exam-ready.' });
  fiHistory.push({ role:'user', content: userContent });
  clearFloatImage();

  const typingBubble = addFloatMessage('ai', '', true);
  const btn = document.getElementById('float-send-btn');
  if(btn) btn.style.opacity = '0.45';

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system: TUTOR_SYSTEM.replace('{{PORTAL_CONTEXT}}', buildPortalContext()),
        messages: fiHistory
      })
    });
    const data = await res.json();
    const reply = data?.content?.[0]?.text || 'Sorry, no response. Try again.';
    fiHistory.push({ role:'assistant', content:reply });
    renderFIResponse(reply, typingBubble);
  } catch(e) {
    if(typingBubble) typingBubble.innerHTML = '⚠️ Connection error. Try again.';
  }

  if(btn) btn.style.opacity = '1';
  if(msgs) msgs.scrollTop = msgs.scrollHeight;
}

// ── Paste (Ctrl+V) image support ──
function handlePasteImage(e, mode) {
  const items = e.clipboardData?.items;
  if(!items) return false;
  for(const item of items) {
    if(item.type.startsWith('image/')) {
      e.preventDefault();
      const file = item.getAsFile();
      if(!file) continue;
      const reader = new FileReader();
      reader.onload = ev => {
        const dataUrl = ev.target.result;
        const base64 = dataUrl.split(',')[1];
        const mediaType = file.type || 'image/png';
        if(mode === 'tutor') {
          tutorPendingImage = { base64, mediaType };
          const preview = document.getElementById('tutor-img-preview');
          const thumb   = document.getElementById('tutor-img-thumb');
          if(thumb)   thumb.src = dataUrl;
          if(preview) preview.style.display = 'inline-flex';
          // Flash the preview to signal paste worked
          if(preview) { preview.style.outline='2px solid var(--purple)'; setTimeout(()=>preview.style.outline='',600); }
        } else {
          floatPendingImage = { base64, mediaType };
          const preview = document.getElementById('float-img-preview');
          const thumb   = document.getElementById('float-img-thumb');
          if(thumb)   thumb.src = dataUrl;
          if(preview) preview.style.display = 'block';
          if(preview) { preview.style.outline='2px solid var(--purple)'; setTimeout(()=>preview.style.outline='',600); }
        }
      };
      reader.readAsDataURL(file);
      return true;
    }
  }
  return false;
}

function handleTutorPaste(e) { handlePasteImage(e, 'tutor'); }
function handleFloatPaste(e)  { handlePasteImage(e, 'float'); }


let floatPendingImage = null;

function handleFloatImage(input) {
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const dataUrl = e.target.result;
    floatPendingImage = { base64: dataUrl.split(',')[1], mediaType: file.type || 'image/jpeg' };
    const preview = document.getElementById('float-img-preview');
    const thumb = document.getElementById('float-img-thumb');
    if(thumb) thumb.src = dataUrl;
    if(preview) preview.style.display = 'block';
  };
  reader.readAsDataURL(file);
  input.value = '';
}

function clearFloatImage() {
  floatPendingImage = null;
  const preview = document.getElementById('float-img-preview');
  if(preview) preview.style.display = 'none';
  const thumb = document.getElementById('float-img-thumb');
  if(thumb) thumb.src = '';
}

