        <div style="font-size:0.82rem;color:var(--text2);line-height:1.55">${f}</div>
      </div>`;
    });
    html += `</div></div>`;
  }

  html += `<div style="padding:12px 16px;background:rgba(155,127,199,0.08);border-radius:var(--r2);border:1px solid rgba(155,127,199,0.2);font-size:0.82rem;color:var(--text2)">${adhdTips[currentDay]}</div>`;

  document.getElementById('daily-content').innerHTML = html;
}

renderDailyContent();

