      </div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:6px">
          <span style="font-size:0.7rem;font-weight:800;color:${tc2.dot};text-transform:uppercase;letter-spacing:0.4px">Week ${d.week} · ${d.label}${dateStr?' · '+dateStr:' · Day '+d.day}</span>
          ${isToday ? `<span style="font-size:0.62rem;font-weight:800;padding:2px 7px;background:${tc2.bg};border:1px solid ${tc2.dot};border-radius:99px;color:${tc2.dot}">TODAY</span>` : ''}
        </div>
        <div style="font-size:0.82rem;font-weight:700;color:${isDone?'var(--text3)':'var(--text)'};${isDone?'text-decoration:line-through;':''}">${d.title}</div>
        <div style="font-size:0.72rem;color:var(--text3);margin-top:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${d.desc}</div>
      </div>
      <div style="font-size:0.68rem;font-weight:800;padding:3px 9px;border-radius:99px;flex-shrink:0;
          background:${tc2.bg};border:1px solid ${tc2.border};color:${tc2.dot}">${d.type==='off'?'Off':d.type.charAt(0).toUpperCase()+d.type.slice(1)}</div>
    </div>`;
  }).join('');
}

function toggleCoiDay(dayNum) {
  const key = 'coiDay_'+dayNum;
  const current = localStorage.getItem(key);
  try { localStorage.setItem(key, current==='done' ? '' : 'done'); } catch(e){}
  renderCOICalendar();
}

// Init calendar
(function(){
  const stored = localStorage.getItem('coiStartDate');
  if(stored) { const el = document.getElementById('coi-start-date'); if(el) el.value = stored; }
