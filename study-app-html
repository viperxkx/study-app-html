  {term:"What are the mortgagee's special rights under the mortgage clause?", def:"Sue in their own name, pay policy premiums, and submit proof of loss. Their recovery rights cannot be defeated by any act or neglect of the insured."},
  {term:"Real property vs. personal property — what's the difference?", def:"Real property = non-movable (houses, structures). Personal property = movable (autos, mobile homes, furniture, equipment)."},
  {term:"What is salvage in insurance?", def:"The amount recovered from the sale of damaged property after a total loss is paid. After settling a total loss claim, the insurer takes ownership of the damaged property and has the right to sell it to recoup part of the payout."},
  {term:"What is the difference between appraisal and arbitration?", def:"Both resolve disputes between insurer and insured about a claim. Property disputes use APPRAISAL (each party picks an appraiser). Casualty disputes use ARBITRATION (submitted to an arbitrator). Same concept, different sides."},
  {term:"What are the 5 sources of insurability information used in underwriting?", def:"1) Application form  2) Motor vehicle records  3) Interviews with neighbors/friends/employers  4) Inspection of property  5) Inspection of insurance history"},
  {term:"What act is the FCRA administered by, and what does it protect?", def:"Administered by the Federal Trade Commission (FTC). Protects consumers from circulation of inaccurate or obsolete personal or financial information."},
  {term:"What does the Gramm-Leach-Bliley Act require regarding customer disclosures?", def:"2 disclosures: (1) when the customer relationship is established and (2) before disclosing protected information. Plus annual privacy disclosure and the right to opt out."},
  {term:"Under Gramm-Leach-Bliley, when may an insurer disclose nonpublic personal info to a third party?", def:"Only if: consumer is clearly notified in writing, given opportunity to opt out BEFORE disclosure, and provided explanation of how to exercise nondisclosure."},
  {term:"What is TRIA?", def:"Terrorism Risk Insurance Act — a temporary federal program that shares the risk of loss from terrorist attacks with the insurance industry. Requires commercial insurers to offer terrorism coverage."},
  {term:"Who certifies an act of terrorism under TRIA?", def:"The Secretary of the Treasury + Secretary of Homeland Security + Attorney General of the United States."},
  {term:"Name 4 types of insurance excluded from TRIA coverage.", def:"Any 4 of: crop insurance, private mortgage insurance, title insurance, medical malpractice, life & health, federal flood, reinsurance, commercial auto, burglary & theft, surety, professional liability (except D&O), farm owners multiple peril."},
  {term:"What is the government reimbursement rate under TRIPRA 2019?", def:"80% of covered terrorism losses exceeding the insurer's deductible. Extended through December 31, 2027."},
  {term:"What did the 2007 TRIA Reauthorization change?", def:"Removed the requirement that terrorists act on behalf of a foreign person/interest. Added $100 billion cap disclosure to policyholders. Treasury must notify Congress within 15 days if losses exceed $100B."},
  {term:"Persons who are not named on the declarations page but are protected by the policy are known as what?", def:"Additional insured"},
  {term:"What is proof of loss?", def:"A sworn written statement from an insured notifying the insurer about a loss. Must be signed and submitted — required before a loss can be paid."},
  {term:"What is a warranty in an insurance contract?", def:"An absolutely true statement upon which the validity of the policy depends. Much stricter than a representation — breach of warranty can void the policy."},
  {term:"What does an endorsement do to an insurance contract?", def:"It modifies the policy's original terms, conditions, or coverages. Must be in writing, attached to the policy, and signed by an executive officer of the insurer."},
  {term:"What insurance principle does pro rata liability protect?", def:"Indemnity — ensures the insured cannot collect more than the actual loss by proportionally splitting the loss among all policies covering the same risk."},
  {term:"When does pro rata liability apply?", def:"When an insured has more than one policy covering the same loss. Each policy pays a proportional share based on its limits versus the total coverage."},
  {term:"When is an appraisal needed and how can it be requested?", def:"When the insured and insurer disagree about the value of a property loss. Either party can make a written demand for an appraisal — each picks an appraiser, and if they can't agree, an umpire is selected."},
  {term:"What provision defines how a policy responds if there is more than one insurance policy written on the same risk?", def:"Other insurance provision (pro rata liability)"},
  {term:"In insurance contracts, when is the offer usually made?", def:"When the insurance application is submitted — the applicant makes the offer."},
  {term:"In insurance contracts, when does acceptance usually occur?", def:"When the insurer approves a prepaid application."},
  {term:"What is consideration in an insurance contract?", def:"Something of value each party gives to the other. The insured's consideration = premium + statements on the application. The insurer's consideration = the promise to pay in the event of a covered loss."},
  {term:"What part of a policy contains the insurer's promise to pay a claim?", def:"The Insuring Agreement"},
  {term:"What part of a policy indicates the general rules or procedures that the insurer and insured agree to follow?", def:"The Conditions section"},
  {term:"What part of a policy shows the amount of insurance, premium, and policy terms?", def:"The Declarations page"},
  {term:"What section personalizes an insurance policy?", def:"The Declarations page — contains the insured's name, address, coverage amounts, premiums, and description of insured property."},
  {term:"What is additional coverage in an insurance policy?", def:"A provision that adds more coverage for a specific loss at no additional premium."},
  {term:"Which method of loss valuation is contrary to the principle of indemnity?", def:"Replacement cost — because it pays to replace the property new, which may exceed the actual financial loss, allowing the insured to potentially profit."},
  {term:"In commercial property policies, who has control of the policy and who can cancel it?", def:"The First Named Insured — the first person listed on the declarations. They have full control: can cancel, request changes, pay premiums, and report losses."},
]];

let currentDeck=[...decks[0]],cardIndex=0;
function loadDeck(idx,el){
  document.querySelectorAll('#view-flashcards .ch-tab').forEach(p=>p.classList.remove('active'));
  if(el)el.classList.add('active');
  currentDeck=[...decks[idx]];cardIndex=0;renderCard();
}
function renderCard(){
  const c=currentDeck[cardIndex],n=currentDeck.length;
  document.getElementById('fc-term').textContent=c.term;
  document.getElementById('fc-def').textContent=c.def;
  document.getElementById('fc-counter').textContent=`${cardIndex+1} / ${n}`;
  document.getElementById('fc-cr').textContent=`${cardIndex+1} / ${n}`;
  document.getElementById('fc-lbl').textContent=`Card ${cardIndex+1} of ${n}`;
  document.getElementById('fc-prog').style.width=`${Math.round(((cardIndex+1)/n)*100)}%`;
  document.getElementById('flashcard').classList.remove('flipped');
}
function flipCard(){document.getElementById('flashcard').classList.toggle('flipped');}
function nextCard(){cardIndex=(cardIndex+1)%currentDeck.length;renderCard();}
function prevCard(){cardIndex=(cardIndex-1+currentDeck.length)%currentDeck.length;renderCard();}
function shuffleDeck(){for(let i=currentDeck.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[currentDeck[i],currentDeck[j]]=[currentDeck[j],currentDeck[i]];}cardIndex=0;renderCard();}
function restartDeck(){cardIndex=0;renderCard();}

// QUIZ — Official ExamFX Ch.1 Quiz (15 questions)
const quizzes=[[
  {q:"A $100,000 house insured on a policy with an 80% coinsurance requirement has a fire that caused $40,000 of damage; the owner has a policy with $60,000 coverage. How much can the owner collect for his loss?",opts:["$30,000","$20,000","$40,000","$60,000"],answer:0,exp:"Formula: (Carried ÷ Required) × Loss = Payment. Required = $100K × 80% = $80K. ($60K ÷ $80K) × $40K = 0.75 × $40K = $30,000. They only carried 75% of the required amount, so they only get 75% of the loss paid."},
  {q:"What are the two types of compensatory damages?",opts:["Punitive and general","Special and general","Direct and indirect","Absolute and strict"],answer:1,exp:"The two types of compensatory damages are Special (out-of-pocket measurable costs: medical bills, lost wages) and General (non-economic: pain & suffering, mental anguish, disfigurement)."},
  {q:"A Certificate of Insurance is a written document that:",opts:["Allows the insurer to inspect the insured's books","Names the insured's beneficiary","Shows the types and amounts of insurance issued to the insured","Obligates the insurer to the person to whom the insurance was issued"],answer:2,exp:"A Certificate of Insurance is proof only — it shows the types and amounts of coverage that exist. It does NOT obligate the insurer to the certificate holder or change the policy in any way."},
  {q:"The insured's house is located one mile from the county's new landfill and across the road from the entrance of a rock quarry. It would cost $150,000 to rebuild the house if something happened to it, but when the insured tried to sell it, the best offer he received was $80,000. The insurance company will insure the house for only $80,000. What method of valuation is used to insure this property?",opts:["Actual cost value","Replacement cost","Functional replacement cost","Market value"],answer:3,exp:"Market value accounts for land, location, and outside factors — the landfill and rock quarry dragged the value below rebuild cost. $80,000 is what a buyer would pay on the open market, not what it costs to rebuild ($150,000)."},
  {q:"The risk of loss may be classified as:",opts:["Direct and indirect","Pure and speculative","Physical and moral","Absolute and strict"],answer:1,exp:"Risk is classified as Pure risk (loss only or no change — insurable) or Speculative risk (loss OR gain, like gambling — NOT insurable). These are the only two classifications tested."},
  {q:"Which of the following best describes negligence?",opts:["A situation that creates a probability of loss","The failure to use reasonable and prudent care","The inability to meet the burden of proof","A latent defect or fault in property"],answer:1,exp:"Negligence = failure to act as a reasonable, prudent person under the circumstances. 'Reasonable and prudent' is the key phrase. A = describes a hazard. C = a legal/court concept. D = describes a physical hazard."},
  {q:"One driver makes a left turn on a red light and is hit by another driver who is speeding through the intersection. The driver making the illegal turn is found to be 80% guilty of the accident, while the speeding driver is 20% at fault. According to the principle of comparative negligence, how much will the speeding driver be able to collect on the claim?",opts:["50%","100%","20%","80%"],answer:3,exp:"Comparative negligence: you collect damages minus your own fault percentage. The speeding driver is 20% at fault, so they can collect 100% − 20% = 80% of their damages. They recover what the OTHER party is responsible for."},
  {q:"Liability imposed on one party as a result of the actions of another person is known as:",opts:["Absolute liability","Strict liability","Vicarious liability","Comparative liability"],answer:2,exp:"Vicarious liability = one party held liable for the actions of another. Classic examples: employer liable for employee (respondeat superior), parent liable for minor child, car owner liable for permitted driver."},
  {q:"When a direct chain of events resulting from a negligent act causes injury or damage, that act is considered to be:",opts:["The indirect cause","The proximate cause","The contributing cause","The absolute cause"],answer:1,exp:"Proximate cause = the direct, unbroken chain of events from a negligent act to the injury. Key phrase: 'exact, direct, and uninterrupted cause of loss.' This is what triggers coverage."},
  {q:"What is the purpose of the coinsurance clause found in property insurance policies?",opts:["To allow the insurer to cancel the policy for underinsurance","To encourage insureds to insure their property close to its value","To limit the insurer's total payout","To prevent the insured from having multiple policies"],answer:1,exp:"The coinsurance clause encourages insureds to carry insurance close to the property's full value. Penalty for underinsuring: only partial payment on losses via the coinsurance formula (Carried ÷ Required × Loss = Payment)."},
  {q:"An additional loss that results from a direct loss of property is called a/n:",opts:["Peril","Proximate loss","Indirect loss","Absolute loss"],answer:2,exp:"Indirect (or consequential) loss results FROM a direct loss. Examples: loss of income while business is closed for repairs, extra living expenses while home is uninhabitable, lost rental income. Direct loss causes the indirect loss."},
  {q:"An insured's 9-year-old son threw a ball, accidentally breaking a neighbor's plate glass window. The insured was found legally liable for the cost of replacing the window. This is an example of:",opts:["Absolute liability","Strict liability","Contributory negligence","Vicarious liability"],answer:3,exp:"Vicarious liability — the parent is held legally responsible for the actions of their minor child. Same concept as employer/employee (respondeat superior). The insured did nothing wrong themselves but is liable for another's actions."},
  {q:"What do individuals use to transfer their risk of loss to a larger group?",opts:["Subrogation","Indemnity","Insurance","Hazard transfer"],answer:2,exp:"Insurance is the mechanism by which an individual transfers their risk of loss to a larger group (the insurer), which then spreads the cost among all insureds. This is the fundamental definition of insurance."},
  {q:"Which of the following does the term proximate cause refer to?",opts:["Reason for filing a lawsuit","Negligence that leads to an injury","Duty of the defendant to act","Injury that leads to monetary compensation"],answer:1,exp:"Proximate cause = the negligent act that starts the direct, unbroken chain of events resulting in injury or damage. It is the direct cause that triggers liability and insurance coverage. A = reason to sue. C = the 'duty' element. D = describes damages."},
  {q:"Which type of risk is the ONLY type that insurance companies are willing to insure?",opts:["Speculative risk","Morale risk","Pure risk","Physical risk"],answer:2,exp:"Pure risk = only possible outcomes are loss or no change (no chance of gain). Insurance can only spread the cost of PURE risks. Speculative risks involve possible gain (gambling, investing) and are NOT insurable."},
],[
  {q:"Which of the following is NOT one of the 4 required elements of a valid insurance contract?",opts:["Agreement","Consideration","Insurable Interest","Legal Purpose"],answer:2,exp:"The 4 elements are Agreement, Consideration, Competent Parties, and Legal Purpose (A.C.C.L.). Insurable interest is required for the policy to be valid but is NOT one of the 4 contract elements."},
  {q:"In an insurance contract, the applicant's consideration consists of:",opts:["Only the payment of premium","Only the statements on the application","Payment of premium AND statements on the application","The promise to pay in the event of loss"],answer:2,exp:"The insured's consideration = premium payment PLUS the representations (statements) made on the application. The insurer's consideration = the promise to pay for covered losses."},
  {q:"A statement made on an insurance application that is believed to be true but is NOT guaranteed to be true is called a:",opts:["Warranty","Representation","Concealment","Binder"],answer:1,exp:"Representations are statements believed to be true to the best of one's knowledge. They are NOT guaranteed to be true. Warranties are absolute guarantees — a much stricter standard."},
  {q:"If an applicant intentionally withholds material information from an insurer, this is called:",opts:["Misrepresentation","Fraud","Concealment","Warranty breach"],answer:2,exp:"Concealment is the intentional withholding of material information that would affect the underwriting decision. It may void the policy. Misrepresentation involves providing false information, while concealment involves hiding true information."},
  {q:"A material misrepresentation that is intentional is considered:",opts:["A warranty","Concealment","Fraud","A binder"],answer:2,exp:"A material misrepresentation is a false statement that would change the insurer's underwriting decision. When intentional, it crosses the line into fraud."},
  {q:"A binder is best described as:",opts:["A permanent insurance policy","A temporary agreement providing coverage until a policy is issued","A type of endorsement","A declarations page"],answer:1,exp:"A binder is a temporary agreement (written or verbal) that provides coverage until the actual policy can be issued. It expires when the policy is issued."},
  {q:"When does a binder expire if the insurer decides NOT to issue the policy?",opts:["Immediately upon the insurer's decision","30 days after the application is submitted","The day after the insured receives notice of cancellation","At the end of the policy term"],answer:2,exp:"If the insurer declines to issue the policy, the binder expires the day AFTER the insured receives the notice of cancellation — giving the insured one day of protection after notice."},
  {q:"Which section of an insurance policy is typically the first page and contains the insured's name, address, and coverage amounts?",opts:["Conditions","Insuring Agreement","Declarations","Definitions"],answer:2,exp:"The Declarations page is the first page and contains the basic underwriting info: insured's name, address, coverage amounts, premiums, and description of insured locations."},
  {q:"The section of a policy that establishes the insurer's obligation to provide coverage is called the:",opts:["Declarations","Conditions","Exclusions","Insuring Agreement"],answer:3,exp:"The Insuring Agreement (or Agreement clause) is where the insurer makes its promise to provide coverage. It lists parties, effective dates, description of coverage, and perils."},
  {q:"An endorsement to an insurance policy must be:",opts:["Verbal and agreed upon by both parties","In writing, attached to the policy, and signed by an executive officer of the insurer","Approved by the state insurance department","Added only at policy renewal"],answer:1,exp:"Endorsements must be in writing, physically attached to the policy, AND signed by an executive officer of the insurer to have any effect on the contract."},
  {q:"The liberalization clause in a policy states that:",opts:["Premiums may be increased during the policy term","If the insurer introduces improved free coverage, the insured gets it immediately","The insurer may cancel the policy at any time","The insured must report losses within 24 hours"],answer:1,exp:"The liberalization clause (found in Conditions) ensures that if the insurer broadens coverage at no extra charge, the insured automatically gets the benefit immediately — without waiting for renewal."},
  {q:"Which of the following is an example of a water damage EXCLUSION under a property policy?",opts:["A burst pipe inside the home","A fire sprinkler malfunction","Flood water from a nearby river","Rain entering through a broken window"],answer:2,exp:"The water damage exclusion specifically excludes flood, subsurface water, sewer/drain backup, and sump pump overflow. Internal pipe bursts and sprinkler malfunctions are typically covered perils."},
  {q:"In a commercial policy, who has the authority to cancel the policy?",opts:["Any named insured","The additional insured","The first named insured only","Any insured listed on the declarations"],answer:2,exp:"In commercial policies, the FIRST named insured has exclusive control: they alone may cancel the policy, request changes, are responsible for premiums, and must report losses."},
  {q:"An additional insured is typically added to a policy by:",opts:["A verbal agreement","The declarations page","An endorsement","A binder"],answer:2,exp:"Additional insureds are added by endorsement. They do not appear on the declarations page but are given coverage for a specific interest under the policy."},
  {q:"After a theft loss, the insured must notify the police.", opts:["True","False"], answer:0, exp:"Notifying police is one of the insured's duties after a theft loss. The 5 duties are: Protect property, Prepare inventory, Cooperate with insurer, Notify police (theft), and submit signed sworn Proof of Loss (P.P.C.N.P.)."},
  {q:"In P&C insurance, an assignment of a policy is valid:",opts:["At any time without restriction","Only with prior written consent of the insurer","After the policy expires","Only with verbal agreement of both parties"],answer:1,exp:"In property and casualty insurance, policy assignments are valid ONLY with the prior written consent of the insurer. This protects the insurer from unknowingly covering a risk they didn't underwrite."},
  {q:"When there is a disagreement between the insured and insurer on the value of a loss, either party may:",opts:["File a lawsuit immediately","Make a written demand for an appraisal","Cancel the policy","Request a policy endorsement"],answer:1,exp:"The appraisal provision allows either party to make a written demand for appraisal. Each selects an appraiser, and if they can't agree on a value, they jointly select an umpire."},
  {q:"The pro rata other insurance provision is designed to:",opts:["Allow the insured to collect full loss from each policy","Ensure the insured profits from a loss","Share the loss proportionally among all policies covering the same risk","Require all policies to cover the same perils"],answer:2,exp:"Pro rata other insurance preserves the principle of indemnity. Each policy pays a share proportional to its limits vs. total coverage. The insured cannot collect more than the actual loss."},
  {q:"Which of the following statements about Proof of Loss is correct?",opts:["It can be submitted verbally","It is required at the beginning of the claims process","It is a sworn written statement required before a loss can be paid","It is the same as a Notice of Claim"],answer:2,exp:"Proof of Loss must always be in WRITING (it's a sworn statement) and is required near the END of the claims process — not at the beginning. Notice of Claim (initial report) can be oral or written."},
  {q:"A consent to settle provision is most commonly found in:",opts:["Homeowners policies","Auto policies","Professional liability policies","Life insurance policies"],answer:2,exp:"The consent to settle provision is found in professional liability (errors & omissions, malpractice) policies. It requires the insurer to get the insured's approval before settling a claim, protecting the insured's professional reputation."},
  {q:"What is the difference between cancellation and nonrenewal?",opts:["They are the same thing","Cancellation occurs before expiration; nonrenewal occurs at expiration","Nonrenewal occurs before expiration; cancellation occurs at expiration","Cancellation requires mutual consent; nonrenewal does not"],answer:1,exp:"Cancellation = termination BEFORE the policy expiration date (mid-term). Nonrenewal = the insurer simply does not renew the policy at its natural expiration date."},
  {q:"Under the standard mortgage clause, which of the following is TRUE about a mortgagee's rights?",opts:["The mortgagee can collect more than their remaining debt if the loss is large enough","The mortgagee's rights can be defeated by the insured's negligence","The mortgagee must receive prior written notice of policy cancellation","The mortgagee cannot pay premiums on behalf of the insured"],answer:2,exp:"The mortgagee must receive prior written notice before a policy is cancelled. Also: (A) wrong — mortgagee never receives more than their insurable interest (remaining debt); (B) wrong — mortgagee's rights cannot be defeated by insured's acts; (D) wrong — mortgagee CAN pay premiums."},
  {q:"Which of the following is classified as REAL property?",opts:["An automobile","A mobile home","A house","Office furniture"],answer:2,exp:"Real property = non-movable property such as houses and permanent structures. Personal property = movable items such as autos, mobile homes, furniture, and equipment."},
  {q:"The Fair Credit Reporting Act (FCRA) is administered by which federal agency?",opts:["Department of Insurance","Federal Trade Commission (FTC)","Department of Treasury","Financial Industry Regulatory Authority"],answer:1,exp:"The FCRA is administered by the Federal Trade Commission (FTC). It protects consumers from the distribution of inaccurate or obsolete personal or financial information, and establishes procedures for consumer-reporting agencies."},
  {q:"Under the Gramm-Leach-Bliley Act, how many disclosures must be made to a customer?",opts:["1 — only when the policy is purchased","2 — when the relationship is established and before disclosing protected information","3 — initial, annual, and at cancellation","No disclosures are required if the customer opts in"],answer:1,exp:"Gramm-Leach-Bliley requires exactly 2 disclosures to a customer: (1) when the customer relationship is established (policy purchased) and (2) before disclosing protected information. Customers also receive an annual privacy notice and the right to opt out."},
  {q:"Under the Gramm-Leach-Bliley Act, what right does a customer have regarding their private information?",opts:["The right to sue the insurer","The right to opt out of having their information shared with nonaffiliated third parties","The right to demand the insurer destroy their records","The right to view all underwriting files"],answer:1,exp:"Under Gramm-Leach-Bliley, customers have the right to opt out — meaning they can choose NOT to have their nonpublic personal information shared with nonaffiliated third parties."},
  {q:"TRIA (Terrorism Risk Insurance Act) applies to which of the following?",opts:["Federal flood insurance","Medical malpractice insurance","Commercial property and liability insurance","Life and health insurance"],answer:2,exp:"TRIA applies to commercial property and liability insurance, workers compensation, excess insurance, and directors & officers insurance. It specifically EXCLUDES: life/health, federal flood, medical malpractice, commercial auto, crop insurance, reinsurance, and others."},
  {q:"Under TRIPRA 2019, what percentage of covered terrorism losses above the deductible does the federal government reimburse?",opts:["50%","70%","80%","100%"],answer:2,exp:"The 2019 TRIPRA reauthorization fixed the government reimbursement rate at 80% of covered terrorism losses exceeding the insurer's deductible. The program was extended through December 31, 2027."},
]];

let currentQuiz=[],quizIdx=0,score=0,answered=false,correctArr=[];
function startQuiz(idx){currentQuiz=quizzes[idx];quizIdx=0;score=0;correctArr=[];answered=false;renderQuestion();}
function renderQuestion(){
  if(quizIdx>=currentQuiz.length){showResult();return;}
  const q=currentQuiz[quizIdx];answered=false;
  const ok=correctArr.filter(Boolean).length,bad=correctArr.filter(v=>v===false).length;
  const pct=Math.round((quizIdx/currentQuiz.length)*100);
  document.getElementById('quiz-container').innerHTML=`
    <div class="quiz-topbar">
      <div class="quiz-score-row"><span class="qdot" style="background:var(--green)"></span>${ok}<span class="qdot" style="background:var(--red);margin-left:8px"></span>${bad}</div>
      <div class="quiz-prog-track"><div class="quiz-prog-fill" style="width:${pct}%"></div></div>
      <div style="font-size:0.78rem;color:var(--text3);white-space:nowrap">${quizIdx+1} / ${currentQuiz.length}</div>
    </div>
    <div class="gc">
      <div class="quiz-q">${q.q}</div>
      <div class="quiz-opts">${q.opts.map((o,i)=>`<button class="qopt" onclick="selectAnswer(${i})" id="qo${i}"><span class="q-letter">${String.fromCharCode(65+i)}</span>${o}</button>`).join('')}</div>
      <div class="quiz-exp" id="qexp"><div class="qexp-lbl">→ Explanation</div>${q.exp}</div>
      <div id="qnxt"></div>
    </div>`;
}
function selectAnswer(sel){
  if(answered)return;answered=true;
  const q=currentQuiz[quizIdx],ok=sel===q.answer;
  correctArr.push(ok);if(ok)score++;
  document.querySelectorAll('.qopt').forEach((b,i)=>{b.disabled=true;if(i===q.answer)b.classList.add('correct');else if(i===sel&&!ok)b.classList.add('wrong');});
  document.getElementById('qexp').classList.add('show');
  document.getElementById('qnxt').innerHTML=`<button class="btn btn-sm" style="margin-top:8px" onclick="nextQuestion()">${quizIdx+1<currentQuiz.length?'Next →':'See Results →'}</button>`;
}
function nextQuestion(){quizIdx++;renderQuestion();}
function showResult(){
  const pct=Math.round((score/currentQuiz.length)*100);
  const col=pct>=80?'var(--green)':pct>=70?'var(--amber)':'var(--red)';
  const msg=pct>=80?'★ Excellent! You are ready for this chapter!':pct>=70?'↑ Good work — review missed questions.':'▦ Keep studying — review notes then retake.';
  document.getElementById('quiz-container').innerHTML=`<div class="gc result-card"><div class="result-big" style="color:${col}">${pct}%</div><div style="color:var(--text3);font-size:0.88rem;margin-bottom:6px">${score} / ${currentQuiz.length} correct</div><div class="result-msg">${msg}</div><div class="btn-row"><button class="btn-ghost" onclick="startQuiz(0)">Retake</button><button class="btn" onclick="switchViewById('notes')">Notes</button><button class="btn-ghost" onclick="switchViewById('flashcards')">Flashcards</button></div></div>`;
}
renderCard();

